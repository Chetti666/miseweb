---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
}

const {
  title,
  description = 'Motion graphics, producción de video profesional y contenido multimedia en Santiago, Chile. Especialistas en diseño audiovisual estratégico para marcas y empresas.',
  keywords = 'carlogtz, carlo gtz, carlo gutierrez, productora audiovisual, servicios audiovisuales, producción de video profesional, motion graphics, videos corporativos, desarrollo de cursos e-learning, productora audiovisual en Santiago, creación de contenido digital',
  image = '/media/isotipo.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.carlogtz.cl');

const siteBase = 'https://www.carlogtz.cl';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteBase}/#organization`,
  "name": "Carlo Gtz",
  "url": siteBase,
  "description": "Productora audiovisual en Santiago de Chile. Especialistas en producción de video profesional, motion graphics, videos corporativos y desarrollo de cursos e-learning.",
  "logo": {
    "@type": "ImageObject",
    "url": `${siteBase}/media/isotipo.png`,
    "width": 1200,
    "height": 630
  },
  "sameAs": [
    "https://www.youtube.com/@carlogtz"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+56-9-4855-8736",
    "contactType": "customer service",
    "email": "carlogtz@gmail.com",
    "availableLanguage": ["Spanish", "es-CL"]
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santiago",
    "addressRegion": "Región Metropolitana",
    "addressCountry": "CL"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteBase}/#localbusiness`,
  "name": "Carlo Gtz",
  "description": "Motion graphics, producción de video profesional y contenido multimedia en Santiago, Chile.",
  "url": siteBase,
  "telephone": "+56-9-4855-8736",
  "email": "carlogtz@gmail.com",
  "image": `${siteBase}/media/isotipo.png`,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santiago",
    "addressRegion": "Región Metropolitana",
    "addressCountry": "CL"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -33.4489,
    "longitude": -70.6693
  },
  "areaServed": { "@type": "Country", "name": "Chile" },
  "sameAs": ["https://www.youtube.com/@carlogtz"],
  "parentOrganization": { "@id": `${siteBase}/#organization` }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteBase}/#website`,
  "url": siteBase,
  "name": "Carlo Gtz - Productora Audiovisual",
  "description": "Productora audiovisual en Santiago de Chile. Especialistas en producción de video profesional, motion graphics, videos corporativos y desarrollo de cursos e-learning.",
  "publisher": {
    "@id": `${siteBase}/#organization`
  },
  "inLanguage": "es-CL"
};

const breadcrumbLabels: Record<string, string> = {
  '/': 'Inicio',
  '/portfolio': 'Portafolio',
  '/sobre-mi': 'Sobre mí',
  '/contacto': 'Contacto'
};

const breadcrumbItems = [];
const path = Astro.url.pathname;
breadcrumbItems.push({
  "@type": "ListItem",
  "position": 1,
  "name": "Inicio",
  "item": siteBase
});
if (path !== '/') {
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 2,
    "name": breadcrumbLabels[path] || path.slice(1).replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    "item": `${siteBase}${path}`
  });
}
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/media/fav_negro.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/media/fav_blanco.svg" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es-CL" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Logo de Carlo Gtz" />
    <meta property="og:site_name" content="Carlo Gtz - Productora Audiovisual" />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    
    <meta name="robots" content="index, follow, max-snippet:150, max-image-preview:large" />
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  </head>
  <body class="bg-base text-ink antialiased min-h-screen">
    <div class="noise-layer" aria-hidden="true"></div>
    
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />

    <ContactModal />

    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>

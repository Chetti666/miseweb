---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const {
  title,
  description = 'Productora audiovisual en Santiago de Chile. Especialistas en producción de video profesional, motion graphics, videos corporativos y desarrollo de cursos e-learning para empresas.',
  keywords = 'productora audiovisual, servicios audiovisuales, producción de video profesional, motion graphics, videos corporativos, desarrollo de cursos e-learning, productora audiovisual en Santiago, creación de contenido digital'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/media/fav_negro.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/media/fav_blanco.svg" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
  </head>
  <body class="bg-base text-ink antialiased">
    <div class="noise-layer" aria-hidden="true"></div>
    
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

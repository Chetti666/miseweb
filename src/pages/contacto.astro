---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contacto | CG Motion Studio" description="Contacta al estudio para cotizar edicion de video y direccion creativa.">
  <section class="section-shell py-18 md:py-24">
    <span class="chip">Contacto</span>
    <h1 class="section-title mt-6 max-w-3xl text-white">Cuentame tu proyecto y en 24 horas te envio una propuesta inicial.</h1>
  </section>

  <section class="section-shell grid gap-8 pb-20 md:grid-cols-[1.2fr_0.8fr]">
    <form class="glass-card grid gap-4 p-6 md:p-8" action="#" method="post">
      <label class="text-sm text-white/80">Nombre
        <input type="text" name="nombre" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="Tu nombre" />
      </label>
      <label class="text-sm text-white/80">Correo
        <input type="email" name="email" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="hola@marca.com" />
      </label>
      <label class="text-sm text-white/80">Tipo de proyecto
        <select name="tipo" class="mt-2 w-full rounded-xl border border-white/20 bg-base px-4 py-3 text-white outline-none focus:border-[var(--color-accent)]">
          <option>Reels y anuncios</option>
          <option>Brand motion</option>
          <option>Contenido mensual</option>
        </select>
      </label>
      <label class="text-sm text-white/80">Mensaje
        <textarea name="mensaje" rows="5" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="Objetivo, plazos y referencias"></textarea>
      </label>
      <button type="submit" class="mt-2 rounded-full bg-accent px-5 py-3 font-semibold text-left transition hover:brightness-110">Enviar briefing</button>
    </form>

    <aside class="space-y-4">
      <article class="glass-card p-6">
        <h2 class="font-display text-2xl text-white">Contacto directo</h2>
        <p class="mt-2 text-white/75">hello@cgmotion.studio</p>
        <p class="text-white/75">+54 9 11 1234 5678</p>
      </article>
      <article class="glass-card p-6">
        <h2 class="font-display text-2xl text-white">Canales</h2>
        <div class="mt-3 flex gap-3 text-sm">
          <a class="rounded-full border border-white/20 px-4 py-2 text-white/80 hover:bg-white/10 hover:text-white" href="https://instagram.com" target="_blank" rel="noreferrer">Instagram</a>
          <a class="rounded-full border border-white/20 px-4 py-2 text-white/80 hover:bg-white/10 hover:text-white" href="https://vimeo.com" target="_blank" rel="noreferrer">Vimeo</a>
        </div>
      </article>
    </aside>
  </section>
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
---

<MainLayout title="Contacto | Productora Audiovisual en Santiago | Carlo Gtz" description="Contacta a nuestro equipo para cotizar servicios audiovisuales, videos corporativos y desarrollo de cursos e-learning en Chile.">
  <section class="section-shell py-14 md:py-12" data-page-enter>
    <span class="chip" data-reveal>Contacto</span>
    <h1 class="section-title mt-6 max-w-3xl text-white" data-hero-title>Cotiza tu proyecto audiovisual y te envio una propuesta inicial.</h1>
  </section>

  <section class="section-shell grid gap-8 pb-20 md:grid-cols-[1.2fr_0.8fr]" data-page-enter>
    <form class="glass-card grid gap-4 p-6 md:p-8" action="/api/contact" method="POST" data-reveal>
      
      <!-- Mensaje de estado dinámico -->
      <div id="status-message" class="hidden rounded-xl p-4 font-mono text-sm"></div>
      
      <label class="text-sm font-mono text-white/90">Nombre
        <input type="text" name="nombre" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 font-mono text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="Tu nombre" />
      </label>
      <label class="text-sm font-mono text-white/90">Correo
        <input type="email" name="email" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 font-mono text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="hola@marca.com" />
      </label>
      <label class="text-sm font-mono text-white/90">Tipo de proyecto
        <select name="tipo" class="mt-2 w-full rounded-xl border border-white/20 bg-base px-4 py-3 font-mono text-white outline-none focus:border-[var(--color-accent)]">
          <option value="">Selecciona un tipo</option>
          <option value="video">Video Corporativo</option>
          <option value="motion">Motion Graphics</option>
          <option value="elearning">Curso E-learning</option>
          <option value="contenido">Contenido para Redes</option>
          <option value="otro">Otro</option>
        </select>
      </label>
      <label class="text-sm font-mono text-white/90">Mensaje
        <textarea name="mensaje" rows="5" class="mt-2 w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3 font-mono text-white outline-none placeholder:text-white/35 focus:border-[var(--color-accent)]" placeholder="Objetivo, plazos y referencias"></textarea>
      </label>
      <button type="submit" class="mt-2 rounded-full bg-accent px-5 py-3 font-mono font-semibold text-left transition hover:brightness-110">Enviar briefing</button>
    </form>

    <aside class="space-y-4" data-reveal>
      <article class="glass-card p-6">
        <h2 class="font-display text-2xl text-white">Contacto directo</h2>
        <p class="mt-2 font-mono text-white/85">Carlo Alberto Gutiérrez Salazar</p>
        <p class="font-mono text-white/85">carlogtz@gmail.com</p>
        <p class="font-mono text-white/85">+569-48558736</p>
      </article>
    </aside>
  </section>

  <ScrollAnimations />

  <script>
    // Detectar parámetros de éxito/error al enviar el formulario
    const urlParams = new URLSearchParams(window.location.search);
    const status = urlParams.get('status');
    const msg = urlParams.get('msg');
    const statusMessage = document.getElementById('status-message');

    if (statusMessage) {
      if (status === 'success') {
        statusMessage.textContent = '¡Mensaje enviado con éxito! Te contactaremos pronto.';
        statusMessage.classList.remove('hidden');
        statusMessage.classList.add('bg-[rgba(8,187,174,0.1)]', 'border', 'border-[rgba(8,187,174,0.3)]', 'text-[var(--color-accent)]');
        // Limpiar URL para que no se reenvíe al recargar
        window.history.replaceState({}, document.title, window.location.pathname);
      } else if (status === 'error') {
        statusMessage.textContent = msg === 'missing_fields'
          ? 'Por favor, completa todos los campos obligatorios.'
          : 'Hubo un error al enviar el mensaje. Intenta de nuevo o escríbenos directamente.';
        statusMessage.classList.remove('hidden');
        statusMessage.classList.add('bg-[rgba(255,107,157,0.1)]', 'border', 'border-[rgba(255,107,157,0.3)]', 'text-[var(--color-accent-3)]');
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    }
  </script>
</MainLayout>

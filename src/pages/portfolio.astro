---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const projects = [
  { title: 'Launch Reel / Moda Urbana', type: 'Social Ads', result: '+4.1M visualizaciones', tone: 'Energetico' },
  { title: 'Brand Film / Estudio Arquitectura', type: 'Branding', result: '+62% retencion', tone: 'Cinematico' },
  { title: 'Product Spot / E-commerce Beauty', type: 'Comercial', result: 'ROAS x3.8', tone: 'Premium' },
  { title: 'Event Recap / Festival', type: 'Cobertura', result: '120k interacciones', tone: 'Documental' },
  { title: 'Identity Motion / SaaS', type: 'Motion', result: 'Nuevo sistema visual', tone: 'Minimal' },
  { title: 'Creator Campaign / Podcast', type: 'Contenido', result: '2x reproducciones', tone: 'Editorial' }
];
---

<MainLayout title="Portafolio | CG Motion Studio" description="Seleccion de proyectos de edicion de video, motion y contenido comercial.">
  <section class="section-shell py-12 md:py-12">
    <span class="chip" data-reveal>PORTAFOLIO</span>
    <h1 class="section-title mt-6 max-w-3xl text-white" data-hero-title>
      Historias visuales disenadas para captar atencion y convertir.
    </h1>
  </section>

  <section class="section-shell pb-20">
    <div class="mb-10 grid gap-8 p-6 md:grid-cols-[1fr_1.2fr] md:p-10 bg-white/[0.02] rounded-lg backdrop-blur-sm" data-featured-pin>
      <div>
        <p class="text-xs font-mono uppercase tracking-[0.2em] text-accent">Proyecto destacado</p>
        <h2 class="mt-3 font-display text-4xl text-white">REEL 2025 / Campana integral</h2>
        <p class="mt-4 text-sm font-mono text-white/50">Montaje vertical con narrativa por bloques, tipografia cinetica y transiciones ritmicas para marcas en crecimiento.</p>
      </div>
      <div class="grid min-h-[360px] place-items-center rounded-lg bg-white/[0.02] p-8 text-center">
        <img src="/media/logo_blanco.svg" alt="Preview de proyecto" class="mb-5 w-32 opacity-60" loading="lazy" />
        <p class="max-w-xs text-xs font-mono text-white/40">Preview temporal. Se reemplazara por clips fraccionados optimizados para web.</p>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => (
        <div class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm hover:bg-white/[0.04] transition-colors" data-reveal>
          <p class="text-xs font-mono uppercase tracking-[0.15em] text-white/40">{project.type}</p>
          <h3 class="mt-3 font-display text-xl text-white">{project.title}</h3>
          <p class="mt-3 text-xs font-mono text-white/50">Resultado: {project.result}</p>
          <p class="mt-1 text-xs font-mono text-accent">Look & feel: {project.tone}</p>
        </div>
      ))}
    </div>
  </section>

  <ScrollAnimations />
</MainLayout>

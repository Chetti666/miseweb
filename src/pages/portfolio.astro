---
import MainLayout from "../layouts/MainLayout.astro";
import ScrollAnimations from "../components/ScrollAnimations.astro";

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Portafolio - Carlo Gtz",
  description:
    "Portafolio de proyectos audiovisuales: edición de video, motion graphics, comerciales y contenido digital.",
  url: "https://www.carlogtz.cl/portfolio",
  isPartOf: {
    "@id": "https://www.carlogtz.cl/#website",
  },
  inLanguage: "es-CL",
};

const projects = [
  {
    title: "Lixiviación | AM LOTUS",
    type: "Motion Graphics",
    result: "Video corporativo",
    tone: "Minero",
  },
  {
    title: "Programa Familias | Cerro Navia",
    type: "Audiovisual",
    result: "Testimonial municipal",
    tone: "Documental",
  },
  {
    title: "Ley Karin | BHP",
    type: "E-learning",
    result: "Curso interactivo",
    tone: "Corporativo",
  },
];
---

<MainLayout
  title="Portafolio | Carlo Gtz | Motion Graphics & Video Profesional"
  description="Portafolio de proyectos de motion graphics, edición de video profesional y contenido digital en Santiago, Chile. Resultados reales para marcas."
>
  <section class="section-shell py-12 md:py-12">
    <span class="chip" data-reveal>PORTAFOLIO</span>
    <h1 class="section-title mt-6 max-w-3xl text-white" data-hero-title>
      Portafolio de Motion Graphics, Video Profesional y Contenido Digital.
    </h1>
  </section>

  <section class="section-shell pb-20">
    <div class="group relative mb-10" data-service>
      <div
        class="glass-premium relative flex flex-col overflow-hidden md:flex-row items-stretch"
      >
        <div
          class="absolute inset-0 pointer-events-none transition-opacity duration-700"
          style="background: radial-gradient(800px circle at 30% 50%, rgba(8,187,174,0.06) 0%, transparent 70%);"
        >
        </div>
        <div
          class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          style="background: radial-gradient(600px circle at 30% 50%, rgba(8,187,174,0.12) 0%, transparent 70%);"
        >
        </div>

        <div class="w-full md:w-1/2 relative overflow-hidden">
          <div
            class="relative aspect-video md:aspect-auto md:h-full w-full overflow-hidden"
          >
            <video
              src="/media/AM-Lotus_v5.mp4.mp4"
              class="h-full w-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105"
              autoplay
              loop
              muted
              playsinline></video>
            <div
              class="absolute inset-0 pointer-events-none mix-blend-overlay transition-opacity duration-500 group-hover:opacity-0"
              style="background: linear-gradient(135deg, rgba(8,187,174,0.3) 0%, transparent 60%);"
            >
            </div>
          </div>
        </div>

        <div
          class="hidden md:block absolute left-1/2 top-6 bottom-6 w-px opacity-0 group-hover:opacity-100 transition-all duration-500"
          style="background: linear-gradient(to bottom, transparent, rgba(8,187,174,0.35), transparent);"
        >
        </div>

        <div
          class="w-full md:w-1/2 flex flex-col justify-center p-5 md:p-6 lg:p-8 relative"
        >
          <div class="absolute top-4 right-4 flex flex-col items-end">
            <div class="w-6 h-px" style="background: rgba(8,187,174,0.3);">
            </div>
            <div class="h-6 w-px" style="background: rgba(8,187,174,0.3);">
            </div>
          </div>

          <p
            class="text-xs font-mono uppercase tracking-[0.2em]"
            style="color: var(--color-accent);"
          >
            Motion Graphics
          </p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl text-white">
            Lixiviación
          </h2>
          <p class="mt-1 text-sm font-mono text-white/60">Cliente: AM LOTUS</p>
          <p
            class="mt-3 text-sm md:text-base text-white/85 leading-normal font-mono max-w-md"
          >
            Animación corporativa para el sector minero. Visualización de
            procesos de lixiviación con motion graphics técnicos y narrativa
            clara para capacitación y presentaciones.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono transition-all duration-300 hover:scale-105"
              style="background: rgba(8,187,174,0.1); border: 1px solid rgba(8,187,174,0.25); color: var(--color-accent);"
              >Video corporativo</span
            >
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(243,248,255,0.6);"
              >Cliente: AM LOTUS</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="group relative mb-10" data-service>
      <div
        class="glass-premium relative flex flex-col overflow-hidden md:flex-row-reverse items-stretch"
      >
        <div
          class="absolute inset-0 pointer-events-none transition-opacity duration-700"
          style="background: radial-gradient(800px circle at 70% 50%, rgba(143,28,169,0.06) 0%, transparent 70%);"
        >
        </div>
        <div
          class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          style="background: radial-gradient(600px circle at 70% 50%, rgba(143,28,169,0.12) 0%, transparent 70%);"
        >
        </div>

        <div class="w-full md:w-1/2 relative overflow-hidden">
          <div
            class="relative aspect-video md:aspect-auto md:h-full w-full overflow-hidden"
          >
            <video
              src="/media/cerro_navia_no_logo.mp4.mp4"
              class="h-full w-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105"
              autoplay
              loop
              muted
              playsinline></video>
            <div
              class="absolute inset-0 pointer-events-none mix-blend-overlay transition-opacity duration-500 group-hover:opacity-0"
              style="background: linear-gradient(135deg, rgba(143,28,169,0.3) 0%, transparent 60%);"
            >
            </div>
          </div>
        </div>

        <div
          class="hidden md:block absolute right-1/2 top-6 bottom-6 w-px opacity-0 group-hover:opacity-100 transition-all duration-500"
          style="background: linear-gradient(to bottom, transparent, rgba(143,28,169,0.35), transparent);"
        >
        </div>

        <div
          class="w-full md:w-1/2 flex flex-col justify-center p-5 md:p-6 lg:p-8 relative"
        >
          <div class="absolute top-4 left-4 flex flex-col items-start">
            <div class="w-6 h-px" style="background: rgba(143,28,169,0.3);">
            </div>
            <div class="h-6 w-px" style="background: rgba(143,28,169,0.3);">
            </div>
          </div>

          <p
            class="text-xs font-mono uppercase tracking-[0.2em]"
            style="color: var(--color-accent-2);"
          >
            Audiovisual
          </p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl text-white">
            Programa Familias
          </h2>
          <p class="mt-1 text-sm font-mono text-white/60">
            Cliente: Municipalidad Cerro Navia
          </p>
          <p
            class="mt-3 text-sm md:text-base text-white/85 leading-normal font-mono max-w-md"
          >
            Video testimonial para programa municipal. Grabación en terreno con
            vecinos, entrevistas y cobertura documental para visibilizar el
            impacto social del programa Familias en Cerro Navia.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono transition-all duration-300 hover:scale-105"
              style="background: rgba(143,28,169,0.1); border: 1px solid rgba(143,28,169,0.25); color: var(--color-accent-2);"
              >Testimonial municipal</span
            >
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(243,248,255,0.6);"
              >Grabación en terreno</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="group relative mb-10" data-service>
      <div
        class="glass-premium relative flex flex-col overflow-hidden md:flex-row items-stretch"
      >
        <div
          class="absolute inset-0 pointer-events-none transition-opacity duration-700"
          style="background: radial-gradient(800px circle at 30% 50%, rgba(255,107,157,0.06) 0%, transparent 70%);"
        >
        </div>
        <div
          class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          style="background: radial-gradient(600px circle at 30% 50%, rgba(255,107,157,0.12) 0%, transparent 70%);"
        >
        </div>

        <div class="w-full md:w-1/2 relative overflow-hidden">
          <div
            class="relative aspect-video md:aspect-auto md:h-full w-full overflow-hidden"
          >
            <video
              src="/media/BHP_video.mp4.mp4"
              class="h-full w-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105"
              autoplay
              loop
              muted
              playsinline></video>
            <div
              class="absolute inset-0 pointer-events-none mix-blend-overlay transition-opacity duration-500 group-hover:opacity-0"
              style="background: linear-gradient(135deg, rgba(255,107,157,0.3) 0%, transparent 60%);"
            >
            </div>
          </div>
        </div>

        <div
          class="hidden md:block absolute left-1/2 top-6 bottom-6 w-px opacity-0 group-hover:opacity-100 transition-all duration-500"
          style="background: linear-gradient(to bottom, transparent, rgba(255,107,157,0.35), transparent);"
        >
        </div>

        <div
          class="w-full md:w-1/2 flex flex-col justify-center p-5 md:p-6 lg:p-8 relative"
        >
          <div class="absolute top-4 right-4 flex flex-col items-end">
            <div class="w-6 h-px" style="background: rgba(255,107,157,0.3);">
            </div>
            <div class="h-6 w-px" style="background: rgba(255,107,157,0.3);">
            </div>
          </div>

          <p
            class="text-xs font-mono uppercase tracking-[0.2em]"
            style="color: var(--color-accent-3);"
          >
            E-learning
          </p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl text-white">
            Ley Karin
          </h2>
          <p class="mt-1 text-sm font-mono text-white/60">Cliente: BHP</p>
          <p
            class="mt-3 text-sm md:text-base text-white/85 leading-normal font-mono max-w-md"
          >
            Curso interactivo e-learning sobre la Ley Karin. Diseño
            instruccional multimedia con narrativa clara, evaluaciones
            integradas y recursos visuales para capacitación corporativa en
            prevención del acoso laboral.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono transition-all duration-300 hover:scale-105"
              style="background: rgba(255,107,157,0.1); border: 1px solid rgba(255,107,157,0.25); color: var(--color-accent-3);"
              >Curso interactivo</span
            >
            <span
              class="rounded-sm px-3 py-1.5 text-xs font-mono"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(243,248,255,0.6);"
              >Diseño instruccional</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        projects.map((project) => (
          <div
            class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm hover:bg-white/[0.04] transition-colors"
            data-reveal
          >
            <p class="text-xs font-mono uppercase tracking-[0.15em] text-white/60">
              {project.type}
            </p>
            <h3 class="mt-3 font-display text-xl text-white">
              {project.title}
            </h3>
            <p class="mt-3 text-xs font-mono text-white/70">
              Resultado: {project.result}
            </p>
            <p class="mt-1 text-xs font-mono text-accent">
              Look & feel: {project.tone}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageSchema)}
    is:inline
  />
  <ScrollAnimations />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const services = [
  {
    name: 'Video editing comercial',
    bullets: ['Reels, ads y piezas hero', 'Adaptaciones por formato/plataforma', 'Versiones A/B para performance']
  },
  {
    name: 'Motion graphics y identidad',
    bullets: ['Animacion de isotipo y logotipo', 'Sistemas de lower thirds y placas', 'Aperturas y cierres de marca']
  },
  {
    name: 'Direccion creativa de contenido',
    bullets: ['Guia visual mensual', 'Ritmo narrativo por campana', 'Alineacion con objetivos de negocio']
  }
];

const process = ['Brief y estrategia', 'Guion visual', 'Edicion y motion', 'Revision colaborativa', 'Entrega final'];
---

<MainLayout title="Servicios | CG Motion Studio" description="Servicios de edicion de video y direccion creativa para marcas y profesionales.">
  <section class="section-shell py-10 md:py-6" data-page-enter>
    <span class="chip" data-reveal>Servicios</span>
    <h1 class="section-title mt-4 max-w-4xl text-white" data-hero-title>Servicios pensados para marcas que necesitan contenido constante y diferencial.</h1>
  </section>

  <section class="section-shell grid gap-6 pb-14 md:grid-cols-3" data-page-enter>
    {services.map((service) => (
      <article class="glass-card p-4" data-reveal>
        <h2 class="font-display text-2xl text-white">{service.name}</h2>
        <ul class="mt-2 space-y-2 text-white/75">
          {service.bullets.map((bullet) => (
            <li>- {bullet}</li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  <section class="section-shell pb-24" data-page-enter>
    <article class="glass-card p-6 md:p-6" data-reveal="">
      <p class="text-m font-semibold uppercase tracking-[0.2em] text-accent">Proceso</p>
      <ol class="mt-5 grid gap-3 md:grid-cols-5">
        {process.map((step, index) => (
          <li class="rounded-2xl border border-white/12 bg-white/5 p-4 text-center text-sm text-white/85">
            <span class="mb-2 block font-display text-2xl text-accent-2">0{index + 1}</span>
            {step}
          </li>
        ))}
      </ol>
    </article>
  </section>

  <ScrollAnimations />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const services = [
  {
    name: 'Producción Audiovisual',
    video: '/media/AudioVisual_v1.mp4',
    bullets: ['Reels, ads y piezas hero', 'Adaptaciones por formato/plataforma', 'Versiones A/B para performance']
  },
  {
    name: 'Motion Graphics',
    video: '/media/MotionGraphics_v1.mp4',
    bullets: ['Animación de isotipo y logotipo', 'Sistemas de lower thirds y placas', 'Aperturas y cierres de marca']
  },
  {
    name: 'Inteligencia Artificial (IA)',
    video: null,
    bullets: ['Generación de assets visuales', 'Optimización de flujos de trabajo', 'Integración de herramientas IA']
  },
  {
    name: 'E-learning',
    video: null,
    bullets: ['Edición de cursos online', 'Material didáctico audiovisual', 'Videos formativos dinámicos']
  }
];

const process = ['Brief y estrategia', 'Guion visual', 'Edición y motion', 'Revisión colaborativa', 'Entrega final'];
---

<MainLayout
  title="CG Motion Studio | Edicion de video y diseno para marcas"
  description="Web de presentacion para estudio creativo especializado en edicion de video, identidad visual y contenido para marcas."
>
  <section class="section-shell grid min-h-[80vh] items-center gap-10 py-20 md:grid-cols-[1.15fr_0.85fr]" data-parallax-wrap>
    <div class="space-y-6" data-parallax>
      <span class="chip" data-reveal>// VIDEO EDITING + VISUAL DESIGN</span>
      <h1 class="section-title max-w-2xl text-white" data-hero-title>
        Transformamos<span class="text-accent"> ideas</span> en piezas visuales que<span class="text-accent-2"> venden</span>.
      </h1>
      <p class="max-w-xl text-base font-mono text-white/60 leading-relaxed" data-reveal>
        Produccion de reels, anuncios y contenido digital con direccion creativa, narrativa dinamica y foco en resultados para marcas y profesionales.
      </p>
      <div class="flex flex-wrap gap-3 pt-2" data-reveal>
        <a href="/contacto" class="rounded-sm bg-accent px-6 py-3 font-medium text-sm text-base transition hover:bg-accent/80">
          Solicitar propuesta
        </a>
        <a href="/portfolio" class="rounded-sm px-6 py-3 text-sm font-mono text-white/60 transition hover:text-white">
          Ver portafolio
        </a>
      </div>
    </div>

    <div class="relative flex aspect-[9/16] max-h-[560px] items-center justify-center" data-reveal>
      <div class="absolute inset-0 flex items-center justify-center gap-0.5 opacity-25">
        {[...Array(24)].map((_, i) => (
          <div class="waveform-bar" style={`height: ${Math.random() * 40 + 20}px; animation-delay: ${i * 0.05}s`}></div>
        ))}
      </div>
      <img src="/media/logo_blanco.svg" alt="CG Motion Studio" class="mx-auto mb-4 w-32 relative z-10 opacity-80" loading="lazy" />
      <p class="text-xs font-mono text-white/40 absolute bottom-8 relative z-10">
        REEL EN ACTUALIZACION
      </p>
    </div>
  </section>

  <section class="section-shell py-16" data-reveal>
    <div class="grid gap-4 md:grid-cols-3">
      <div class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm">
        <p class="text-4xl font-bold text-accent font-display">+240<span class="text-2xl">%</span></p>
        <h2 class="mt-3 font-display text-xl text-white tracking-wide">Engagement</h2>
        <p class="mt-2 text-xs font-mono text-white/50">Mejora media en campanas de video social</p>
      </div>
      <div class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm">
        <p class="text-4xl font-bold text-accent-2 font-display">72<span class="text-2xl">h</span></p>
        <h2 class="mt-3 font-display text-xl text-white tracking-wide">Entrega agile</h2>
        <p class="mt-2 text-xs font-mono text-white/50">Flujo de trabajo rapido para lanzamientos</p>
      </div>
      <div class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm">
        <p class="text-4xl font-bold text-white font-display">360<span class="text-2xl">+</span></p>
        <h2 class="mt-3 font-display text-xl text-white tracking-wide">Proyectos</h2>
        <p class="mt-2 text-xs font-mono text-white/50">Direccion integral de principio a fin</p>
      </div>
    </div>
  </section>

  <section id="servicios" class="section-shell py-20" data-reveal>
    <div class="mb-8">
      <span class="chip">SERVICIOS</span>
      <h2 class="section-title mt-4 text-white">Que hacemos</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <div class="group" data-reveal>
          {service.video ? (
            <div class="relative aspect-video w-full overflow-hidden rounded-lg">
              <video
                src={service.video}
                class="h-full w-full object-cover opacity-70 transition-opacity duration-500 group-hover:opacity-90"
                autoplay
                loop
                muted
                playsinline
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#090f1a] via-transparent to-transparent"></div>
            </div>
          ) : (
            <div class="relative flex aspect-video w-full items-center justify-center bg-white/[0.02] rounded-lg">
              <span class="text-xs font-mono tracking-[0.3em] text-white/15 uppercase">Proximamente</span>
            </div>
          )}
          <div class="p-2 -mt-2 relative z-10">
            <h3 class="font-display text-xl text-white tracking-wide opacity-90 group-hover:opacity-100 transition-opacity">{service.name}</h3>
            <ul class="mt-2 space-y-1 text-xs font-mono text-white/40">
              {service.bullets.map((bullet) => (
                <li class="flex items-start gap-2">
                  <span class="text-accent mt-0.5 opacity-70">▸</span> {bullet}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-shell pb-24" data-reveal>
    <div class="p-5 bg-white/[0.02] rounded-lg backdrop-blur-sm">
      <p class="text-xs font-mono font-semibold uppercase tracking-[0.25em] text-accent">PROCESO</p>
      <ol class="mt-4 grid gap-2 md:grid-cols-5">
        {process.map((step, index) => (
          <li class="p-3 text-center relative">
            <span class="mb-1 block font-display text-xl text-accent-2 tracking-wider">{String(index + 1).padStart(2, '0')}</span>
            <span class="text-xs font-mono text-white/50">{step}</span>
            {index < process.length - 1 && (
              <span class="hidden md:block absolute right-0 top-1/2 -translate-y-1/2 text-white/10">→</span>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <ScrollAnimations />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const services = [
  {
    name: 'Producción Audiovisual',
    video: '/media/AudioVisual_v1.mp4',
    bullets: ['Reels, ads y piezas hero', 'Adaptaciones por formato/plataforma', 'Versiones A/B para performance']
  },
  {
    name: 'Motion Graphics',
    video: '/media/MotionGraphics_v1.mp4',
    bullets: ['Animación de isotipo y logotipo', 'Sistemas de lower thirds y placas', 'Aperturas y cierres de marca']
  },
  {
    name: 'Inteligencia Artificial (IA)',
    video: null,
    bullets: ['Generación de assets visuales', 'Optimización de flujos de trabajo', 'Integración de herramientas IA']
  },
  {
    name: 'E-learning',
    video: null,
    bullets: ['Edición de cursos online', 'Material didáctico audiovisual', 'Videos formativos dinámicos']
  }
];

const process = ['Brief y estrategia', 'Guion visual', 'Edición y motion', 'Revisión colaborativa', 'Entrega final'];
---

<MainLayout
  title="CG Motion Studio | Edicion de video y diseno para marcas"
  description="Web de presentacion para estudio creativo especializado en edicion de video, identidad visual y contenido para marcas."
>
  <section class="section-shell grid min-h-[80vh] items-center gap-10 py-20 md:grid-cols-[1.15fr_0.85fr]" data-parallax-wrap>
    <div class="space-y-8" data-parallax>
      <span class="chip" data-reveal>Video Editing + Visual Design</span>
      <h1 class="section-title max-w-2xl text-5xl leading-[0.95] text-white md:text-7xl" data-hero-title>
        Transformamos ideas en piezas visuales que venden.
      </h1>
      <p class="max-w-xl text-lg text-white/80" data-reveal>
        Produccion de reels, anuncios y contenido digital con direccion creativa, narrativa dinamica y foco
        en resultados para marcas y profesionales.
      </p>
      <div class="flex flex-wrap gap-3" data-reveal>
        <a href="/contacto" class="rounded-full bg-accent px-6 py-3 font-semibold text-base transition hover:brightness-110">
          Solicitar propuesta
        </a>
        <a href="/portfolio" class="rounded-full border border-white/25 px-6 py-3 text-white transition hover:bg-white/10">
          Ver portafolio
        </a>
      </div>
    </div>

    <article class="glass-card grid aspect-[9/16] max-h-[600px] place-items-center p-8 text-center" data-reveal>
      <img src="/media/logo_blanco.svg" alt="CG Motion Studio" class="mx-auto mb-6 w-36" loading="lazy" />
      <p class="text-white/70">
        Reel principal en actualizacion. Aqui iremos integrando clips livianos por secciones y overscroll.
      </p>
    </article>
  </section>

  <section class="section-shell py-16" data-reveal>
    <div class="grid gap-6 md:grid-cols-3">
      <article class="glass-card p-6">
        <p class="text-4xl font-bold text-accent">+240%</p>
        <h2 class="mt-4 font-display text-2xl text-white">Engagement</h2>
        <p class="mt-2 text-white/75">Mejora media en campanas de video social para clientes de nicho lifestyle.</p>
      </article>
      <article class="glass-card p-6">
        <p class="text-4xl font-bold text-accent-2">72h</p>
        <h2 class="mt-4 font-display text-2xl text-white">Entrega agile</h2>
        <p class="mt-2 text-white/75">Flujo de trabajo rapido para lanzamientos, eventos y contenido always-on.</p>
      </article>
      <article class="glass-card p-6">
        <p class="text-4xl font-bold text-white">360+</p>
        <h2 class="mt-4 font-display text-2xl text-white">Direccion integral</h2>
        <p class="mt-2 text-white/75">Concepto visual, edicion, motion graphics y supervision de identidad de marca.</p>
      </article>
    </div>
  </section>

  <section id="servicios" class="section-shell py-20" data-reveal>
    <div class="mb-8">
      <span class="chip">Servicios</span>
      <h2 class="section-title mt-4 text-white">Qué hacemos</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {services.map((service) => (
        <article class="glass-card flex flex-col overflow-hidden" data-reveal>
          {service.video ? (
            <div class="relative aspect-video w-full border-b border-white/10 bg-black/20">
              <video
                src={service.video}
                class="absolute inset-0 h-full w-full object-cover"
                autoplay
                loop
                muted
                playsinline
              />
            </div>
          ) : (
            <div class="relative flex aspect-video w-full items-center justify-center border-b border-white/10 bg-white/5">
              <span class="text-xs font-semibold tracking-[0.2em] text-white/30 uppercase">Próximamente</span>
            </div>
          )}
          <div class="p-6 md:p-8 flex-1 flex flex-col">
            <h3 class="font-display text-2xl text-white">{service.name}</h3>
            <ul class="mt-4 space-y-2 text-white/75 flex-1">
              {service.bullets.map((bullet) => (
                <li>- {bullet}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell pb-24" data-reveal>
    <article class="glass-card p-6 md:p-6">
      <p class="text-m font-semibold uppercase tracking-[0.2em] text-accent">Proceso</p>
      <ol class="mt-5 grid gap-3 md:grid-cols-5">
        {process.map((step, index) => (
          <li class="rounded-2xl border border-white/12 bg-white/5 p-4 text-center text-sm text-white/85">
            <span class="mb-2 block font-display text-2xl text-accent-2">0{index + 1}</span>
            {step}
          </li>
        ))}
      </ol>
    </article>
  </section>

  <ScrollAnimations />
</MainLayout>

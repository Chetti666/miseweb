---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const services = [
  {
    name: 'Producción Audiovisual',
    description: [
      'Creamos contenido audiovisual estratégico para marcas y empresas que buscan comunicar con claridad, captar atención y generar impacto.',
      'Desarrollamos piezas diseñadas para campañas digitales, redes sociales y comunicación corporativa, combinando dirección creativa, narrativa visual y producción profesional.',
      'Cada proyecto se adapta al formato y plataforma donde será publicado, optimizando el contenido para lograr mayor alcance, comprensión y resultados.'
    ],
    video: '/media/AudioVisual_v1.mp4',
    bullets: []
  },
  {
    name: 'Motion Graphics',
    description: [
      'Diseñamos animaciones y gráficos en movimiento que ayudan a explicar ideas, reforzar mensajes y darle identidad visual a cada proyecto audiovisual.',
      'El motion graphics permite transformar información compleja en contenido claro, dinámico y fácil de comprender, ideal para videos corporativos, capacitación, contenido digital y presentaciones de marca.',
      'Cada animación se desarrolla con un enfoque narrativo y visual que potencia la comunicación y la experiencia del espectador.'
    ],
    video: '/media/MotionGraphics_v1.mp4',
    bullets: []
  },
  {
    name: 'Inteligencia Artificial (IA)',
    description: [
      'Utilizamos herramientas de inteligencia artificial para ampliar las posibilidades de la producción audiovisual, creando imágenes, animaciones y secuencias visuales que serían difíciles o costosas de producir con métodos tradicionales.',
      'La IA nos permite generar conceptos visuales únicos, explorar estilos creativos y desarrollar contenido innovador para proyectos audiovisuales, campañas digitales y piezas experimentales.',
      'Combinamos creatividad, dirección visual y tecnología para producir contenido que integra lo mejor del diseño audiovisual con las nuevas capacidades de la inteligencia artificial'
    ],
    video: null,
    bullets: []
  },
  {
    name: 'E-learning',
    description: [
      'Desarrollamos contenido audiovisual para cursos e-learning pensado en mejorar la experiencia de aprendizaje de los estudiantes.',
      'A través de videos formativos dinámicos, recursos visuales y narrativa clara, transformamos contenidos complejos en material didáctico fácil de comprender y recordar.',
      'Nuestro enfoque busca mantener la atención del alumno, facilitar la comprensión de los conceptos y generar una experiencia de aprendizaje más atractiva, efectiva y accesible desde cualquier lugar.'
    ],
    video: null,
    bullets: []
  }
];

const process = [
  'Levantamiento de contenido, ideas, objetivos.',
  'Desarrollo de guion, storyboard, propuestas.',
  'Desarrollo, grabación, edición, prueba y error.',
  'Revisión colaborativa cruzada, modificaciones.',
  'Entrega final, en un periodo de tiempo razonable.'
];
---

<MainLayout
  title="CG Motion Studio | Edicion de video y diseno para marcas"
  description="Web de presentacion para estudio creativo especializado en edicion de video, identidad visual y contenido para marcas."
>
  <div class="grain-overlay"></div>
  <section class="section-shell grid min-h-[80vh] items-center gap-10 py-10 md:grid-cols-[1.15fr_0.85fr]" data-parallax-wrap>
    <div class="space-y-6">
      <div class="[perspective:1000px]">
        <span class="chip inline-block" data-hero-subtitle>// PRODUCCIÓN AUDIOVISUAL + CONTENIDO PARA EMPRESAS</span>
      </div>
      <h1 class="section-title max-w-2xl text-white">
        <span class="hero-text-wrapper inline-block [perspective:1000px]" data-hero-title>
          <span class="hero-text-word inline-block">Transformamos</span>
          <span class="text-accent hero-text-word inline-block"> ideas</span>
          <span class="hero-text-word inline-block"> en contenido</span>
          <span class="hero-text-word inline-block"> audiovisual</span>
          <span class="hero-text-word inline-block"> que genera</span>
          <span class="text-accent-2 hero-text-word inline-block"> resultados</span>
          <span class="hero-text-word inline-block">.</span>
        </span>
      </h1>
      <div class="[perspective:1000px]">
        <p class="hero-text-description max-w-xl text-base font-mono text-white/60 leading-relaxed inline-block" data-hero-description>
          Producción de videos corporativos, contenido para redes, reels publicitarios y piezas audiovisuales diseñadas para comunicar, capacitar y potenciar marcas.
        </p>
      </div>
      <div class="[perspective:1000px]">
        <div class="flex flex-wrap gap-3 pt-2 inline-flex" data-hero-cta>
          <a href="/contacto" class="btn-primary rounded-sm bg-accent px-6 py-3 font-medium text-sm text-base">
            Solicitar propuesta
          </a>
          <a href="/portfolio" class="link-hover rounded-sm px-6 py-3 text-sm font-mono text-white/60">
            Ver portafolio
          </a>
        </div>
      </div>
    </div>

    <div class="relative flex aspect-[9/16] max-h-[560px] items-center justify-center" data-hero-visual>
      <div class="absolute inset-0 flex items-center justify-center gap-0.5 opacity-25">
        {[...Array(24)].map((_, i) => (
          <div class="waveform-bar" style={`height: ${Math.random() * 40 + 20}px; animation-delay: ${i * 0.05}s`}></div>
        ))}
      </div>
      <img src="/media/logo_blanco.svg" alt="CG Motion Studio" class="mx-auto mb-4 w-32 relative z-10 opacity-80 animate-float" loading="lazy" />
      <p class="text-xs font-mono text-white/40 absolute bottom-8 relative z-10">
        REEL EN ACTUALIZACION
      </p>
    </div>
  </section>

  <section id="servicios" class="section-shell py-20">
    <div class="mb-16" data-reveal>
      <span class="chip">SERVICIOS</span>
      <h2 class="section-title mt-4 text-white">Que hacemos</h2>
    </div>

    <div class="flex flex-col gap-20 md:gap-32" data-stagger>
      {services.map((service, index) => (
        <div class={`group flex flex-col items-center gap-8 md:gap-16 ${index % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row'}`} data-service>
          <div class="w-full md:w-1/2">
            {service.video ? (
              <div class="relative aspect-video w-full overflow-hidden rounded-sm bg-white/5">
                <video
                  src={service.video}
                  class="h-full w-full object-cover opacity-70 transition-opacity duration-500 group-hover:opacity-100"
                  autoplay
                  loop
                  muted
                  playsinline
                />
              </div>
            ) : (
              <div class="flex aspect-video w-full items-center justify-center bg-white/5 rounded-sm">
                <span class="font-mono text-sm text-white/30">[Medio no disponible]</span>
              </div>
            )}
          </div>
          <div class="w-full md:w-1/2 flex flex-col justify-center">
            <h3 class="mb-4 font-display text-3xl md:text-4xl text-white" data-reveal>{service.name}</h3>
            
            {service.description && service.description.length > 0 && (
              <div class="mb-6 flex flex-col gap-4" data-reveal>
                {service.description.map((paragraph) => (
                  <p class="text-base md:text-lg text-white/70 leading-relaxed">{paragraph}</p>
                ))}
              </div>
            )}

            {service.bullets && service.bullets.length > 0 && (
              <ul class="flex flex-wrap gap-3" data-reveal>
                {service.bullets.map((bullet, i) => (
                  <li class="rounded-sm bg-white/5 px-3 py-1.5 text-xs font-mono text-accent-2 border border-white/10" style={`transition-delay: ${i * 0.05}s`}>
                    {bullet}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-shell pb-24" data-reveal>
    <div class="mb-12">
      <span class="chip">METODOLOGÍA</span>
      <h2 class="section-title mt-4 text-white">Nuestro Proceso</h2>
    </div>
    
    <div class="relative pl-4 md:pl-12" style="perspective: 1200px;">
      <div class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-accent/40 via-accent-2/40 to-accent/40 hidden md:block process-line"></div>
      <ol class="flex flex-col gap-2 md:gap-3" data-stagger-process>
        {process.map((step, index) => (
          <li class="group relative" data-process-step data-step-index={index}>
            <div class={[
              'glass-card relative overflow-hidden p-4 md:p-5 transition-all duration-500 border-l-2 border-white/10 group-hover:border-accent/60 process-step-card',
              index % 2 === 0 ? 'mr-4 md:mr-16' : 'ml-4 md:ml-16'
            ].join(' ')} style="perspective: 800px;">
              <div class="absolute top-0 right-0 w-20 h-20 bg-accent/5 rounded-full blur-xl group-hover:bg-accent/10 transition-all duration-500"></div>
              <div class="absolute bottom-0 left-0 w-16 h-16 bg-accent-2/5 rounded-full blur-lg group-hover:bg-accent-2/10 transition-all duration-500"></div>
              
              <div class="relative z-10 flex items-start gap-3 md:gap-4">
                <div class="relative flex h-9 w-9 md:h-10 md:w-10 shrink-0 items-center justify-center rounded-lg bg-white/5 border border-white/10 transition-all duration-500 group-hover:border-accent/50 group-hover:bg-accent/10 process-step-number-wrap" style="perspective: 400px;">
                  <span class="font-display text-lg text-accent-2 transition-all duration-500 group-hover:text-accent group-hover:scale-110 process-step-number">{String(index + 1)}</span>
                  <div class="absolute inset-0 rounded-lg bg-accent/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 animate-pulse"></div>
                  <div class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-500 process-step-glow" style="background: radial-gradient(circle at center, rgba(6,182,212,0.25) 0%, transparent 70%);"></div>
                </div>
                
                <div class="flex-1 pt-1">
                  <span class="text-sm md:text-base text-white/70 transition-colors duration-300 group-hover:text-white leading-relaxed block process-step-text">{step}</span>
                  <div class="mt-2 h-0.5 w-10 bg-gradient-to-r from-accent to-accent-2 transition-all duration-700 ease-out group-hover:w-16 process-progress"></div>
                </div>
              </div>
              
              <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-5 h-5 rounded-full bg-surface border-2 border-white/20 hidden md:flex items-center justify-center process-dot">
                <div class="w-2 h-2 rounded-full bg-accent-2/50 group-hover:bg-accent group-hover:scale-125 transition-all duration-300"></div>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <ScrollAnimations />
</MainLayout>

---
import MainLayout from '../layouts/MainLayout.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';

const services = [
  {
    name: 'Producción de Video Profesional',
    idName: 'video-profesional',
    description: [
      'Creamos contenido visual estratégico para marcas que buscan comunicar con claridad, captar atención y generar impacto mediante servicios audiovisuales de alta calidad.',
      'Desarrollamos piezas diseñadas para campañas digitales, redes sociales y videos corporativos, combinando dirección creativa, storytelling audiovisual y producción profesional en terreno y estudio.',
      'Cada proyecto se adapta al formato y plataforma donde será publicado, optimizando el contenido audiovisual para lograr mayor alcance, comprensión y resultados reales para tu negocio en Chile y el mundo.'
    ],
    video: '/media/AudioVisual_v1.mp4',
    //bullets: ['Videos corporativos', 'Videos para empresas', 'Productora audiovisual en Santiago', 'Grabación en terreno']
  },
  {
    name: 'Motion Graphics y Animación Digital',
    idName: 'motion-graphics',
    description: [
      'Diseñamos animaciones 2D y 3D, motion design y gráficos en movimiento que ayudan a explicar ideas complejas, reforzar mensajes y darle identidad visual a cada proyecto multimedia.',
      'La animación digital permite transformar información en contenido claro, dinámico y fácil de comprender, ideal para videos de capacitación empresarial, contenido digital y presentaciones de marca.',
      'Cada pieza se desarrolla con un enfoque narrativo y visual que potencia el branding audiovisual, la comunicación y la experiencia del espectador.'
    ],
    video: '/media/MotionGraphics_v1.mp4',
    //bullets: ['Motion graphics', 'Animación digital', 'Animación 2D y 3D', 'Diseño multimedia']
  },
  {
    name: 'Inteligencia Artificial y Producción Creativa',
    idName: 'ia-produccion-creativa',
    description: [
      'Utilizamos herramientas de inteligencia artificial para ampliar las posibilidades de la productora creativa audiovisual, creando imágenes, animaciones y secuencias que potencian la narrativa visual.',
      'La IA nos permite generar conceptos únicos, explorar estilos creativos y desarrollar producción de contenido innovador para proyectos audiovisuales, campañas digitales y experiencias inmersivas.',
      'Combinamos creatividad, dirección técnica y tecnología para producir contenido digital creativo que integra lo mejor del diseño interactivo con las nuevas capacidades tecnológicas.'
    ],
    video: null,
    //bullets: ['Producción de contenido innovador', 'Contenido digital creativo', 'Experiencia audiovisual inmersiva']
  }
];

const process = [
  'Levantamiento de contenido, ideas, objetivos.',
  'Desarrollo de guion, storyboard, propuestas.',
  'Desarrollo, grabación, edición, prueba y error.',
  'Revisión colaborativa cruzada, modificaciones.',
  'Entrega final, en un periodo de tiempo razonable.'
];

const serviceSchemas = services.map((s) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  name: s.name,
  description: s.description[0],
  provider: { "@id": "https://www.carlogtz.cl/#organization" },
  areaServed: { "@type": "Country", name: "Chile" },
  serviceType: s.name,
  url: `https://www.carlogtz.cl/#${s.idName}`
}));

const serviceListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Servicios audiovisuales",
  description: "Servicios de producción audiovisual, motion graphics y contenido digital en Chile.",
  url: "https://www.carlogtz.cl/",
  numberOfItems: services.length,
  itemListElement: services.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: s.name,
    url: `https://www.carlogtz.cl/#${s.idName}`
  }))
};
---

<MainLayout
  title="Motion Graphics & Video Profesional en Chile | Carlo Gtz"
  description="Motion graphics, producción de video profesional y contenido multimedia en Santiago, Chile. Creamos piezas audiovisuales estratégicas para marcas y proyectos digitales."
>
  <div class="grain-overlay"></div>
  <section class="section-shell grid min-h-[90vh] items-center gap-10 py-20 md:grid-cols-[1fr_1fr]" data-parallax-wrap>
<div class="space-y-6 text-left">
  <div class="[perspective:1000px]">
    <strong class="chip inline-block" data-hero-subtitle>// MOTION GRAPHICS & VIDEO PROFESIONAL EN CHILE</strong>
  </div>
  <h1 class="section-title max-w-2xl text-white">
    <span class="hero-text-wrapper inline-block [perspective:1000px]" data-hero-title>
      <span class="hero-text-word inline-block">Motion</span>
      <span class="hero-text-word inline-block">Graphics</span><br>
      <span class="text-accent hero-text-word inline-block">que</span>
      <span class="hero-text-word inline-block">cuentan</span>
      <span class="hero-text-word inline-block">historias</span><br>
      <span class="hero-text-word inline-block">en</span>
      <span class="text-accent-2 hero-text-word inline-block">Chile.</span>
    </span>
  </h1>
  <div class="[perspective:1000px]">
    <p class="hero-text-description max-w-xl text-base font-mono text-white/80 leading-relaxed inline-block" data-hero-description>
      Creo motion graphics, videos profesionales y contenido multimedia en Santiago, Chile.
      Diseño audiovisual estratégico que conecta ideas con emociones y educación.
    </p>
  </div>
  <div class="[perspective:1000px]">
    <div class="flex flex-wrap gap-3 pt-2 inline-flex" data-hero-cta>
      <a href="/portfolio" class="btn-primary rounded-sm bg-base px-6 py-3 font-mono text-sm text-base">
        Ver mi Trabajo
      </a>
      <a href="/contacto" class="link-hover rounded-sm px-6 py-3 text-sm font-mono text-white/80">
        Solicitar Propuesta
      </a>
    </div>
  </div>
</div>

<div class="relative flex aspect-[16/9] max-h-[640px] items-center justify-center" data-hero-visual>
  <div class="relative w-full h-full rounded-md overflow-hidden border border-white/10 bg-black/50 shadow-2xl shadow-accent/10">
    <div class="absolute top-0 left-0 right-0 z-20 px-4 py-3 bg-gradient-to-b from-black/70 to-transparent flex justify-between items-center">
      <span class="text-xs font-mono text-accent tracking-wider uppercase">Reel 2026</span>
    </div>
    <video
      src="/media/reel_home.mp4"
      class="h-full w-full object-cover opacity-90"
      autoplay
      loop
      muted
      playsinline
      id="hero-reel"
    />
    <div class="absolute bottom-0 left-0 right-0 z-20 p-3 bg-gradient-to-t from-black/80 to-transparent" id="custom-controls">
      <div class="flex items-center gap-3">
        <button id="play-pause" class="w-9 h-9 rounded-full bg-accent/20 hover:bg-accent/40 flex items-center justify-center transition-colors border border-accent/50" aria-label="Play/Pause">
          <svg id="play-icon" class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          <svg id="pause-icon" class="w-4 h-4 text-accent hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        
        <div class="flex-1 relative">
          <div class="h-1 bg-white/20 rounded-full overflow-hidden cursor-pointer" id="progress-container">
            <div id="progress-bar" class="h-full bg-accent rounded-full transition-all" style="width: 0%"></div>
          </div>
        </div>
        
        <div class="flex items-center gap-2">
          <button id="mute-btn" class="w-8 h-8 rounded-full hover:bg-white/10 flex items-center justify-center transition-colors" aria-label="Mute/Unmute">
            <svg id="volume-icon" class="w-4 h-4 text-white/80" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
            <svg id="mute-icon" class="w-4 h-4 text-white/80 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
          </button>
          
          <button id="fullscreen-btn" class="w-8 h-8 rounded-full hover:bg-white/10 flex items-center justify-center transition-colors" aria-label="Fullscreen">
            <svg class="w-4 h-4 text-white/80" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
          </button>
        </div>
      </div>
      
      <div class="flex items-center justify-between mt-1">
        <span id="time-current" class="text-xs font-mono text-white/80">0:00</span>
        <span id="time-duration" class="text-xs font-mono text-white/80">0:00</span>
      </div>
    </div>
  </div>
</div>
  </section>

  <section id="servicios" class="section-shell py-20">
    <div class="mb-16" data-reveal>
      <span class="chip font-mono">SERVICIOS</span>
      <h2 class="section-title mt-4 text-white">Que hacemos</h2>
    </div>

    <div class="flex flex-col gap-14 md:gap-20" data-stagger>
      {services.map((service, index) => {
        const accentColors = [
          { rgb: '8,187,174', var: 'var(--color-accent)' },
          { rgb: '143,28,169', var: 'var(--color-accent-2)' },
          { rgb: '255,107,157', var: 'var(--color-accent-3)' }
        ];
        const accent = accentColors[index % 3];
        const isReversed = index % 2 !== 0;
        return (
          <div class="group relative" data-service>
            <div class={`glass-premium relative flex flex-col overflow-hidden ${isReversed ? 'md:flex-row-reverse' : 'md:flex-row'} items-stretch`}>
              
              {/* Background glow bridging both halves */}
              <div class="absolute inset-0 pointer-events-none transition-opacity duration-700" style={`background: radial-gradient(800px circle at ${isReversed ? '70%' : '30%'} 50%, rgba(${accent.rgb},0.06) 0%, transparent 70%);`}></div>
              <div class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700" style={`background: radial-gradient(600px circle at ${isReversed ? '70%' : '30%'} 50%, rgba(${accent.rgb},0.12) 0%, transparent 70%);`}></div>
              
              {/* Video / Media Side */}
              <div class="w-full md:w-1/2 relative overflow-hidden">
                {service.video ? (
                  <div class="relative aspect-video md:aspect-auto md:h-full w-full overflow-hidden">
                    <video
                      src={service.video}
                      class="h-full w-full object-cover opacity-80 transition-all duration-700 group-hover:opacity-100 group-hover:scale-105"
                      autoplay
                      loop
                      muted
                      playsinline
                    />
                    <div class="absolute inset-0 pointer-events-none mix-blend-overlay transition-opacity duration-500 group-hover:opacity-0" style={`background: linear-gradient(135deg, rgba(${accent.rgb},0.3) 0%, transparent 60%);`}></div>
                  </div>
                ) : (
                  <div class="flex aspect-video md:aspect-auto md:h-full w-full items-center justify-center" style={`background: linear-gradient(135deg, rgba(${accent.rgb},0.1), rgba(255,255,255,0.02));`}>
                    <span class="font-mono text-sm text-white/40">[Medio no disponible]</span>
                  </div>
                )}
              </div>
              
              {/* Accent divider between video and text */}
              <div class={`hidden md:block absolute ${isReversed ? 'right-1/2' : 'left-1/2'} top-6 bottom-6 w-px opacity-0 group-hover:opacity-100 transition-all duration-500`} style={`background: linear-gradient(to bottom, transparent, rgba(${accent.rgb},0.35), transparent);`}></div>
              
              {/* Text Side */}
              <div class="w-full md:w-1/2 flex flex-col justify-center p-5 md:p-6 lg:p-8 relative">
                {/* L-corner accent bracket */}
                <div class={`absolute top-4 ${isReversed ? 'left-4' : 'right-4'} flex flex-col ${isReversed ? 'items-start' : 'items-end'}`}>
                  <div class="w-6 h-px" style={`background: rgba(${accent.rgb},0.3);`}></div>
                  <div class="h-6 w-px" style={`background: rgba(${accent.rgb},0.3);`}></div>
                </div>
                
                <h3 class="mb-3 font-display text-2xl md:text-3xl" data-reveal style={`background: linear-gradient(135deg, ${accent.var}, var(--color-ink)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;`}>
                  {service.name}
                </h3>
                
                {service.description && service.description.length > 0 && (
                  <div class="mb-4 flex flex-col gap-2" data-reveal>
                    {service.description.map((paragraph) => (
                      <p class="text-sm md:text-base text-white/85 leading-normal font-mono">{paragraph}</p>
                    ))}
                  </div>
                )}

                {service.bullets && service.bullets.length > 0 && (
                  <ul class="flex flex-wrap gap-3" data-reveal>
                    {service.bullets.map((bullet, i) => (
                      <li class="rounded-sm px-3 py-1.5 text-xs font-mono transition-all duration-300 hover:scale-105" style={`background: rgba(${accent.rgb},0.1); border: 1px solid rgba(${accent.rgb},0.25); color: ${accent.var}; transition-delay: ${i * 0.05}s;`}>
                        {bullet}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="section-shell pb-24" data-reveal>
    <div class="mb-12">
      <span class="chip font-mono">METODOLOGÍA</span>
      <h2 class="section-title mt-4 text-white">Nuestro Proceso</h2>
    </div>
    
    <div class="relative pl-4 md:pl-12" style="perspective: 1200px;">
      <div class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-accent/40 via-accent-2/40 to-accent-3/40 via-accent/40 hidden md:block process-line"></div>
      <ol class="flex flex-col gap-2 md:gap-3" data-stagger-process>
        {process.map((step, index) => {
          const accentColors = [
            { rgb: '8,187,174', var: 'var(--color-accent)', name: 'accent' },
            { rgb: '143,28,169', var: 'var(--color-accent-2)', name: 'accent-2' },
            { rgb: '255,107,157', var: 'var(--color-accent-3)', name: 'accent-3' }
          ];
          const accent = accentColors[index % 3];
          const isEven = index % 2 === 0;
          return (
          <li class="group relative" data-process-step data-step-index={index}>
            <div class={[
              'glass-card relative overflow-hidden p-4 md:p-5 transition-all duration-500 border-l-2 border-white/10 process-step-card',
              isEven ? 'mr-4 md:mr-16' : 'ml-4 md:ml-16'
            ].join(' ')} style={`perspective: 800px; --step-accent: ${accent.var}; --step-accent-rgb: ${accent.rgb};`}>
              <div class="absolute inset-0 pointer-events-none transition-opacity duration-500 opacity-0 group-hover:opacity-100" style={`background: radial-gradient(600px circle at ${isEven ? '80%' : '20%'} 50%, rgba(${accent.rgb},0.08) 0%, transparent 70%);`}></div>
              <div class="absolute top-0 right-0 w-20 h-20 rounded-full blur-xl opacity-30 transition-all duration-500" style={`background: rgba(${accent.rgb},0.15);`}></div>
              <div class="absolute bottom-0 left-0 w-16 h-16 rounded-full blur-lg opacity-20 transition-all duration-500" style={`background: rgba(${accent.rgb},0.12);`}></div>
              
              <div class="relative z-10 flex items-start gap-3 md:gap-4">
                <div class="relative flex h-9 w-9 md:h-10 md:w-10 shrink-0 items-center justify-center rounded-lg border border-white/10 transition-all duration-500 process-step-number-wrap group-hover:scale-110" style={`background: rgba(${accent.rgb},0.08); border-color: rgba(${accent.rgb},0.25);`}>
                  <span class="font-display text-lg transition-all duration-500 process-step-number" style={`color: ${accent.var};`}>{String(index + 1)}</span>
                  <div class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-500 animate-pulse" style={`background: rgba(${accent.rgb},0.2);`}></div>
                  <div class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-500 process-step-glow" style={`background: radial-gradient(circle at center, rgba(${accent.rgb},0.3) 0%, transparent 70%);`}></div>
                </div>
                
                <div class="flex-1 pt-1">
                  <span class="text-sm md:text-base leading-relaxed block process-step-text font-mono transition-colors duration-300 group-hover:text-white" style="color: rgba(243, 248, 255, 0.85);">{step}</span>
                  <div class="mt-2 h-0.5 w-10 transition-all duration-700 ease-out group-hover:w-16 process-progress" style={`background: linear-gradient(90deg, ${accent.var}, rgba(${accent.rgb},0.4));`}></div>
                </div>
              </div>
              
              <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-5 h-5 rounded-full border-2 border-white/20 hidden md:flex items-center justify-center process-dot" style="background: var(--color-surface);">
                <div class="w-2 h-2 rounded-full transition-all duration-300 group-hover:scale-125" style={`background: rgba(${accent.rgb},0.5);`}></div>
              </div>
            </div>
          </li>
          );
        })}
      </ol>
    </div>
  </section>

  <ScrollAnimations />

<script>
  const video = document.getElementById('hero-reel') as HTMLVideoElement;
  const playPauseBtn = document.getElementById('play-pause');
  const playIcon = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');
  const progressContainer = document.getElementById('progress-container');
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  const muteBtn = document.getElementById('mute-btn');
  const volumeIcon = document.getElementById('volume-icon');
  const muteIcon = document.getElementById('mute-icon');
  const fullscreenBtn = document.getElementById('fullscreen-btn');
  const timeCurrent = document.getElementById('time-current');
  const timeDuration = document.getElementById('time-duration');
  const videoContainer = video?.parentElement as HTMLElement;

  function formatTime(seconds: number): string {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  }

  if (video && playPauseBtn && playIcon && pauseIcon) {
    video.addEventListener('loadedmetadata', () => {
      if (timeDuration) timeDuration.textContent = formatTime(video.duration);
    });

    video.addEventListener('timeupdate', () => {
      if (progressBar && video.duration) {
        const progress = (video.currentTime / video.duration) * 100;
        progressBar.style.width = `${progress}%`;
      }
      if (timeCurrent) timeCurrent.textContent = formatTime(video.currentTime);
    });

    playPauseBtn.addEventListener('click', () => {
      if (video.paused) {
        video.play();
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
      } else {
        video.pause();
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
      }
    });

    video.addEventListener('play', () => {
      playIcon.classList.add('hidden');
      pauseIcon.classList.remove('hidden');
    });

    video.addEventListener('pause', () => {
      playIcon.classList.remove('hidden');
      pauseIcon.classList.add('hidden');
    });

    if (progressContainer && progressBar) {
      progressContainer.addEventListener('click', (e) => {
        const rect = progressContainer.getBoundingClientRect();
        const pos = (e.clientX - rect.left) / rect.width;
        if (video.duration) {
          video.currentTime = pos * video.duration;
        }
      });
    }

    if (muteBtn && volumeIcon && muteIcon) {
      muteBtn.addEventListener('click', () => {
        video.muted = !video.muted;
        if (video.muted) {
          volumeIcon.classList.add('hidden');
          muteIcon.classList.remove('hidden');
        } else {
          volumeIcon.classList.remove('hidden');
          muteIcon.classList.add('hidden');
        }
      });
    }

    if (fullscreenBtn && videoContainer) {
      fullscreenBtn.addEventListener('click', () => {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          videoContainer.requestFullscreen();
        }
      });
    }
  }
</script>
  {serviceSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
  ))}
  <script type="application/ld+json" set:html={JSON.stringify(serviceListSchema)} is:inline />
</MainLayout>

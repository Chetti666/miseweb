---
const links = [
  { label: 'Inicio', href: '/' },
  { label: 'Portafolio', href: '/portfolio' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Sobre mi', href: '/sobre-mi' },
  { label: 'Contacto', href: '/contacto' }
];

const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);

// Helper para determinar si un link está activo.
// Para anchors como /#servicios, los marcamos como inactivos por defecto para evitar
// que tanto Inicio como Servicios estén activos al mismo tiempo.
const isActive = (href: string) => {
  if (href.includes('#')) return false;
  return currentPath === normalizePath(href);
};
---

<header id="site-header" class="sticky top-0 z-50 bg-[#090f1a]/80 backdrop-blur-xl border-b border-white/[0.05] transition-colors duration-300 ease-out">
  <div class="mx-auto flex w-[min(1120px,92%)] items-center justify-between py-4 transition-all duration-300 ease-out header-content" data-header-wrapper>
    <a href="/" class="flex items-center gap-3 font-display text-white group" data-header-logo>
      <img src="/media/logo_blanco.svg" alt="CG Motion Studio" class="h-12 w-auto transition-all duration-300 ease-out header-logo group-hover:drop-shadow-[0_0_8px_var(--color-accent-2)]" loading="eager" />
    </a>
    <nav aria-label="Principal" data-header-nav>
      <ul class="hidden items-center gap-1 md:flex">
        {links.map((link) => (
          <li class="relative">
            <a
              href={link.href}
              class:list={[
                'relative z-10 rounded-sm px-4 py-2 text-sm font-medium font-mono tracking-wider transition-all duration-300',
                isActive(link.href) ? 'text-accent font-semibold drop-shadow-[0_0_8px_var(--color-accent)]' : 'text-white/70 hover:text-white hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <details class="relative md:hidden group">
        <summary class="cursor-pointer list-none rounded-sm px-3 py-1.5 text-white/70 hover:text-white transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu">
            <line x1="4" x2="20" y1="12" y2="12"/>
            <line x1="4" x2="20" y1="6" y2="6"/>
            <line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-48 rounded-sm border border-white/10 bg-[#090f1a] p-2 shadow-xl backdrop-blur-xl">
          <ul class="flex flex-col gap-1">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'block px-4 py-2 text-sm font-mono tracking-wider transition-all duration-300',
                    isActive(link.href) ? 'text-accent font-semibold drop-shadow-[0_0_8px_var(--color-accent)]' : 'text-white/70 hover:text-white hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]'
                  ]}
                >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </details>
  </nav>
</div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const headerContent = header?.querySelector('.header-content') as HTMLElement;
  const headerLogo = header?.querySelector('.header-logo') as HTMLImageElement;

  const handleScroll = () => {
    if (!header || !headerContent || !headerLogo) return;
    
    if (window.scrollY > 50) {
      headerContent.style.paddingTop = '0.5rem';
      headerContent.style.paddingBottom = '0.5rem';
      headerLogo.style.height = '2.5rem';
      headerLogo.style.width = 'auto';
      
      // Fondo casi completamente transparente manteniendo el blur
      header.classList.remove('bg-[#090f1a]/80', 'border-b', 'border-white/[0.05]');
      header.classList.add('bg-[#090f1a]/10', 'shadow-md');
    } else {
      headerContent.style.paddingTop = '1rem';
      headerContent.style.paddingBottom = '1rem';
      headerLogo.style.height = '3rem';
      headerLogo.style.width = 'auto';
      
      // Fondo transparente original con borde
      header.classList.add('bg-[#090f1a]/80', 'border-b', 'border-white/[0.05]');
      header.classList.remove('bg-[#090f1a]/10', 'shadow-md');
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>

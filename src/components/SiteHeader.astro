---
const links = [
  { label: 'Inicio', href: '/' },
  { label: 'Portafolio', href: '/portfolio' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Sobre mi', href: '/sobre-mi' },
  { label: 'Contacto', href: '/contacto' }
];

const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);

// Helper para determinar si un link está activo.
// Para anchors como /#servicios, los marcamos como inactivos por defecto para evitar
// que tanto Inicio como Servicios estén activos al mismo tiempo.
const isActive = (href: string) => {
  if (href.includes('#')) return false;
  return currentPath === normalizePath(href);
};
---

<header class="sticky top-0 z-50 border-b border-white/10 backdrop-blur-xl">
  <div class="mx-auto flex w-[min(1120px,92%)] items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3 font-display text-lg tracking-wide text-white">
      <img src="/media/fav_blanco.svg" alt="Isotipo" class="h-10 w-10" loading="eager" />
      <span class="font-semibold [text-shadow:0_0_16px_rgba(255,255,255,0.38),0_8px_24px_rgba(255,255,255,0.22)]">
        CG Motion Studio
      </span>
    </a>
    <nav aria-label="Principal">
      <ul class="hidden items-center gap-2 md:flex">
        {links.map((link) => (
          <li class="relative">
            {isActive(link.href) && (
              <span class="pointer-events-none absolute inset-0 rounded-full bg-white shadow-[0_10px_24px_rgba(255,255,255,0.22)] animate-zoom-in"></span>
            )}
            <a
              href={link.href}
              class:list={[
                'relative z-10 rounded-full px-4 py-2 text-m transition',
                isActive(link.href)
                  ? 'font-semibold text-[#07111f]'
                  : 'text-white/85 hover:bg-white/10 hover:text-white'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <details class="relative md:hidden">
        <summary class="cursor-pointer list-none rounded-full border border-white/15 px-4 py-2 text-sm text-white">
          Menu
        </summary>
        <ul class="absolute right-0 mt-2 w-52 space-y-1 rounded-2xl border border-white/10 bg-black/90 p-2">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block rounded-xl px-4 py-2 transition',
                  isActive(link.href)
                    ? 'bg-white font-semibold text-[#07111f]'
                    : 'text-white/85 hover:bg-white/10 hover:text-white'
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    </nav>
  </div>
</header>

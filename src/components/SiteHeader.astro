---
const links = [
  { label: 'Inicio', href: '/' },
  { label: 'Portafolio', href: '/portfolio' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Sobre mi', href: '/sobre-mi' },
  { label: 'Contacto', href: '/contacto' }
];

const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);

// Helper para determinar si un link está activo.
// Para anchors como /#servicios, los marcamos como inactivos por defecto para evitar
// que tanto Inicio como Servicios estén activos al mismo tiempo.
const isActive = (href: string) => {
  if (href.includes('#')) return false;
  return currentPath === normalizePath(href);
};
---

<header class="sticky top-0 z-50 bg-[#090f1a]/80 backdrop-blur-xl border-b border-white/[0.05]">
  <div class="mx-auto flex w-[min(1120px,92%)] items-center justify-between py-3.5">
    <a href="/" class="flex items-center gap-3 font-display text-lg tracking-wide text-white">
      <img src="/media/fav_blanco.svg" alt="Isotipo" class="h-12 w-12" loading="eager" />
      <span class="font-normal tracking-[0.15em]">
        CG<span class="text-accent">.</span>MOTION
      </span>
    </a>
    <nav aria-label="Principal">
      <ul class="hidden items-center gap-1 md:flex">
        {links.map((link) => (
          <li class="relative">
            {isActive(link.href) && (
              <span class="pointer-events-none absolute inset-0 rounded-sm bg-accent/20 animate-zoom-in"></span>
            )}
            <a
              href={link.href}
              class:list={[
                'relative z-10 rounded-sm px-3.5 py-1.5 text-xs font-medium font-mono tracking-wider transition',
                isActive(link.href)
                  ? 'text-accent'
                  : 'text-white/50 hover:text-white'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <details class="relative md:hidden">
        <summary class="cursor-pointer list-none rounded-sm px-3 py-1.5 text-xs font-mono text-white/50">
          MENU
        </summary>
        <ul class="absolute right-0 mt-2 w-44 space-y-0.5 rounded-lg bg-[#090f1a]/95 backdrop-blur-sm p-1.5">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block rounded-sm px-3 py-2 text-xs font-mono transition',
                  isActive(link.href)
                    ? 'bg-accent/20 text-accent'
                    : 'text-white/50 hover:text-white'
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    </nav>
  </div>
</header>

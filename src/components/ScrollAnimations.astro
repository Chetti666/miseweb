<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    const heroSubtitle = document.querySelector('[data-hero-subtitle]');
    const heroTitle = document.querySelector('[data-hero-title]');
    const heroCta = document.querySelector('[data-hero-cta]');
    const heroVisual = document.querySelector('[data-hero-visual]');

    tl.fromTo(heroSubtitle, 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, delay: 0.2 }
    ).fromTo(heroTitle,
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.9 },
      '-=0.4'
    ).fromTo(heroCta,
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6 },
      '-=0.5'
    ).fromTo(heroVisual,
      { scale: 0.9, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1 },
      '-=0.6'
    );

    document.querySelectorAll('[data-reveal]').forEach((target) => {
      gsap.fromTo(
        target,
        { y: 40, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.7,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: target,
            start: 'top 85%',
            toggleActions: 'play none none reverse'
          }
        }
      );
    });

    document.querySelectorAll('[data-stagger]').forEach((container) => {
      const children = container.querySelectorAll(':scope > *');
      gsap.fromTo(children,
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: container,
            start: 'top 85%'
          }
        }
      );
    });

    const stats = document.querySelectorAll('[data-stat]');
    stats.forEach((stat) => {
      const value = stat.querySelector('[data-stat-value]');
      if (value) {
        const endValue = parseFloat(value.getAttribute('data-end-value')) || 0;
        const suffix = value.getAttribute('data-suffix') || '';
        
        gsap.fromTo(value,
          { innerText: 0 },
          {
            innerText: endValue,
            duration: 1.5,
            snap: { innerText: 1 },
            ease: 'power2.out',
            scrollTrigger: {
              trigger: stat,
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            },
            onUpdate: function() {
              value.innerText = Math.round(this.targets()[0].innerText) + suffix;
            }
          }
        );
      }
    });

    const parallaxTargets = document.querySelectorAll('[data-parallax]');
    parallaxTargets.forEach((target) => {
      const speed = parseFloat(target.getAttribute('data-parallax-speed')) || 0.1;
      gsap.to(target, {
        yPercent: -12 * speed,
        ease: 'none',
        scrollTrigger: {
          trigger: target,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1
        }
      });
    });

    const services = document.querySelectorAll('[data-service]');
    services.forEach((service) => {
      service.addEventListener('mouseenter', () => {
        gsap.to(service, { scale: 1.02, duration: 0.3, ease: 'power2.out' });
      });
      service.addEventListener('mouseleave', () => {
        gsap.to(service, { scale: 1, duration: 0.3, ease: 'power2.out' });
      });
    });
  }
</script>
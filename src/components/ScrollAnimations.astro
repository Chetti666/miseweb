<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    const pageEnterTargets = document.querySelectorAll('[data-page-enter]');

    if (pageEnterTargets.length) {
      gsap.fromTo(
        pageEnterTargets,
        { y: 24, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.85,
          ease: 'power2.out',
          stagger: 0.12
        }
      );
    }

    const heroTitle = document.querySelector('[data-hero-title]');

    if (heroTitle) {
      gsap.fromTo(heroTitle, { y: 36, opacity: 0 }, { y: 0, opacity: 1, duration: 1.1, ease: 'power3.out' });
    }

    document.querySelectorAll('[data-reveal]').forEach((target, index) => {
      gsap.fromTo(
        target,
        { y: 50, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          delay: index * 0.05,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: target,
            start: 'top 84%'
          }
        }
      );
    });

    const parallaxTarget = document.querySelector('[data-parallax]');
    const parallaxWrap = document.querySelector('[data-parallax-wrap]');

    if (parallaxTarget && parallaxWrap) {
      gsap.to(parallaxTarget, {
        yPercent: -12,
        ease: 'none',
        scrollTrigger: {
          trigger: parallaxWrap,
          scrub: true,
          start: 'top bottom',
          end: 'bottom top'
        }
      });
    }

    const featuredPin = document.querySelector('[data-featured-pin]');

    if (featuredPin) {
      ScrollTrigger.create({
        trigger: featuredPin,
        pin: true,
        start: 'top 18%',
        end: '+=280',
        scrub: 0.8
      });
    }
  }
</script>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    const headerLogo = document.querySelector('[data-header-logo]');
    const headerNav = document.querySelector('[data-header-nav]');
    const heroSubtitle = document.querySelector('[data-hero-subtitle]');
    const heroTitleWrapper = document.querySelector('.hero-text-wrapper');
    const heroTitleWords = document.querySelectorAll('.hero-text-word');
    const heroDescription = document.querySelector('[data-hero-description]');
    const heroCta = document.querySelector('[data-hero-cta]');
    const heroVisual = document.querySelector('[data-hero-visual]');
    const footer = document.querySelector('[data-footer]');
    const footerItems = document.querySelectorAll('[data-footer-item]');

    const masterTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    
    // Animar el header SOLO la primera vez que se carga la página en esta sesión
    const shouldAnimateHeader = !sessionStorage.getItem('site_visited');

    if (shouldAnimateHeader && headerLogo && headerNav) {
      sessionStorage.setItem('site_visited', 'true');
      masterTl
        .fromTo(headerLogo,
          { y: -20, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.6 }
        )
        .fromTo(headerNav,
          { y: -20, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.6 },
          '-=0.4'
        );
    } else if (headerLogo && headerNav) {
      // Si es navegación interna a otras vistas, mostrar inmediatamente
      gsap.set([headerLogo, headerNav], { y: 0, opacity: 1 });
    }

    // El offset de la primera animación del Hero depende de si se animó el header
    const initialOffset = shouldAnimateHeader ? '-=0.4' : '0';

    masterTl
      .fromTo(heroSubtitle, 
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.6 },
        initialOffset
      )
      .fromTo(heroTitleWords,
        { opacity: 0, y: 25 },
        { opacity: 1, y: 0, duration: 0.7, stagger: 0.06 },
        '-=0.4'
      )
      .fromTo(heroDescription,
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.5 },
        '-=0.5'
      )
      .fromTo(heroCta,
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.5 },
        '-=0.4'
      )
      .fromTo(heroVisual,
        { opacity: 0, scale: 0.95 },
        { opacity: 1, scale: 1, duration: 0.8 },
        '-=0.5'
      );

    document.querySelectorAll('[data-reveal]').forEach((target) => {
      const isInsideStagger = target.closest('[data-stagger]');
      if (isInsideStagger) return;
      
      gsap.fromTo(
        target,
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.6,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: target,
            start: 'top 85%',
            toggleActions: 'play none none reverse'
          }
        }
      );
    });

    document.querySelectorAll('[data-stagger]').forEach((container) => {
      const children = container.querySelectorAll(':scope > *');
      gsap.fromTo(children,
        { y: 20, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.15,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: container,
            start: 'top 80%'
          }
        }
      );
      
      children.forEach((child) => {
        const revealElements = child.querySelectorAll('[data-reveal]');
        revealElements.forEach((el) => {
          gsap.fromTo(
            el,
            { y: 15, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 0.4,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 90%',
                toggleActions: 'play none none reverse'
              }
            }
          );
        });
      });
    });

    // Process steps animation - clean slide + fade with staggered feel
    document.querySelectorAll('[data-stagger-process]').forEach((container) => {
      const steps = container.querySelectorAll('[data-process-step]');
      const line = container.parentElement?.querySelector('.process-line');
      
      if (line) {
        gsap.fromTo(line,
          { scaleY: 0, transformOrigin: 'top center' },
          {
            scaleY: 1,
            duration: 0.8,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: container,
              start: 'top 80%'
            }
          }
        );
      }
      
      const directionOffsets = [
        { x: -40, rotateY: -15 },
        { x: 40, rotateY: 15 },
        { x: -30, rotateY: -10 },
        { x: 30, rotateY: 10 },
        { x: -20, rotateY: -8 }
      ];
      
      steps.forEach((step, i) => {
        const card = step.querySelector('.process-step-card');
        const numberWrap = step.querySelector('.process-step-number-wrap');
        const number = step.querySelector('.process-step-number');
        const text = step.querySelector('.process-step-text');
        const progress = step.querySelector('.process-progress');
        
        const offset = directionOffsets[i % directionOffsets.length];
        
        gsap.set(card, {
          transformPerspective: 1000,
          transformOrigin: 'center center'
        });
        
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: step,
            start: 'top 85%',
            toggleActions: 'play none none reverse'
          }
        });
        
        tl.fromTo(card,
          {
            opacity: 0,
            x: offset.x,
            rotateY: offset.rotateY,
            scale: 0.95
          },
          {
            opacity: 1,
            x: 0,
            rotateY: 0,
            scale: 1,
            duration: 0.5,
            ease: 'power2.out'
          }
        )
        .fromTo(numberWrap,
          { opacity: 0, scale: 0.5 },
          { opacity: 1, scale: 1, duration: 0.3, ease: 'back.out(1.4)' },
          '-=0.25'
        )
        .fromTo(number,
          { opacity: 0 },
          { opacity: 1, duration: 0.2 },
          '-=0.2'
        )
        .fromTo(text,
          { opacity: 0 },
          { opacity: 1, duration: 0.25, ease: 'power1.out' },
          '-=0.15'
        )
        .fromTo(progress,
          { scaleX: 0, opacity: 0 },
          { scaleX: 1, opacity: 1, duration: 0.4, ease: 'power1.out' },
          '-=0.15'
        );
      });
    });

    const stats = document.querySelectorAll('[data-stat]');
    stats.forEach((stat) => {
      const value = stat.querySelector('[data-stat-value]');
      if (value instanceof HTMLElement) {
        const endValue = parseFloat(value.getAttribute('data-end-value') || '0') || 0;
        const suffix = value.getAttribute('data-suffix') || '';
        
        gsap.fromTo(value,
          { innerText: 0 },
          {
            innerText: endValue,
            duration: 1.5,
            ease: 'power2.out',
            snap: { innerText: 1 },
            onUpdate: function() {
              value.innerText = Math.round(this.targets()[0].innerText) + suffix;
            },
            scrollTrigger: {
              trigger: stat,
              start: 'top 85%'
            }
          }
        );
      }
    });

    const parallaxTargets = document.querySelectorAll('[data-parallax]');
    parallaxTargets.forEach((target) => {
      const speed = parseFloat(target.getAttribute('data-parallax-speed') || '0.1') || 0.1;
      gsap.to(target, {
        yPercent: -12 * speed,
        ease: 'none',
        scrollTrigger: {
          trigger: target,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1
        }
      });
    });

    const services = document.querySelectorAll('[data-service]');
    services.forEach((service) => {
      service.addEventListener('mouseenter', () => {
        gsap.to(service, { scale: 1.02, duration: 0.3, ease: 'power2.out' });
      });
      service.addEventListener('mouseleave', () => {
        gsap.to(service, { scale: 1, duration: 0.3, ease: 'power2.out' });
      });
    });

    // Animación del Footer — solo opacity y transform en hijos (GPU-accelerated)
    if (footer && footerItems.length > 0) {
      // Estado inicial: footer invisible, hijos desplazados
      gsap.set(footer, { opacity: 0 });
      gsap.set(footerItems, { y: 30, opacity: 0 });
      
      // Animar con ScrollTrigger - una sola timeline para footer y sus hijos
      const footerTl = gsap.timeline({
        scrollTrigger: {
          trigger: footer,
          start: 'top 90%', // Se activa cuando casi entra en vista
          toggleActions: 'play none none reverse'
        }
      });

      // Aparecer el fondo (solo opacity)
      footerTl.to(footer, { opacity: 1, duration: 0.8, ease: 'power3.out' })
      // Elementos internos con stagger (subir y aparecer)
      .to(footerItems, { y: 0, opacity: 1, duration: 0.6, stagger: 0.08, ease: 'power3.out' }, '-=0.5');
    }
  }
</script>
---
interface Props {
  phone?: string;
  message?: string;
}

const { 
  phone = "56948558736", 
  message = "Hola, me gustaría obtener más información sobre tus servicios." 
} = Astro.props;

const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a 
  href={whatsappUrl} 
  target="_blank" 
  rel="noreferrer" 
  class="fixed top-24 md:top-28 right-6 z-40 flex items-center gap-2.5 rounded-full border border-white/10 bg-[#05080e]/85 p-3 px-4 shadow-[0_8px_32px_rgba(0,0,0,0.4)] backdrop-blur-xl transition-all duration-300 hover:border-[#08bbae]/40 hover:shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_20px_rgba(8,187,174,0.25)] hover:-translate-y-0.5 group"
  aria-label="Contactar por WhatsApp"
>
  <!-- Luz de estado "En línea" pulsante -->
  <span class="relative flex h-2 w-2">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#08bbae] opacity-75"></span>
    <span class="relative inline-flex h-2 w-2 rounded-full bg-[#08bbae]"></span>
  </span>

  <!-- Icono WhatsApp minimalista en SVG con colores de la web -->
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    width="18" 
    height="18" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2.2" 
    stroke-linecap="round" 
    stroke-linejoin="round" 
    class="text-[#08bbae] transition-transform duration-300 group-hover:scale-110"
  >
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
  </svg>

  <!-- Texto minimalista con fuente de la marca -->
  <span class="font-mono text-xs font-semibold uppercase tracking-wider text-white/85 transition-colors duration-300 group-hover:text-white">
    WhatsApp
  </span>
</a>
